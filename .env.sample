# --- DJANGO CONFIG ---
SECRET_KEY=django-insecure-your-super-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_PORT=8000

# --- POSTGRES ---
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=mydatabase
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CELERY / REDIS ---
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_PORT=6379
# Полный урл базы данных (если используется в settings.py через dj-database-url):
DATABASE_URL=postgresql://myuser:mysecretpassword@db:5432/mydatabase

# --- FLOWER ---
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:super_secret_flower_password
FLOWER_PERSISTENT=true
FLOWER_STATE_DB=/tmp/flower_db

# --- THIRD-PARTY INTEGRATIONS (Не забудьте добавить для проекта) ---
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
TG_BOT_TOKEN=...
TG_CHAT_ID=...
